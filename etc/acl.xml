<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Backend::system">
                    <resource id="Magento_Backend::tools">
                        <resource id="Magento_Indexer::index">
                            <resource id="ETechFlow_AdminReindex::run"
                                      title="Run Indexer Reindex from Admin"
                                      sortOrder="100"/>
                        </resource>
                    </resource>
                </resource>
                <!--
                    Two fixes (v1.0.1):
                    1. Magento_Backend::stores must be a SIBLING of system,
                       not nested under it. Previous version nested it
                       wrongly which caused ACL merge issues.
                    2. Magento_Config::config must nest under
                       stores_settings (Magento Core's parent) — not
                       directly under stores. Otherwise the merger sees
                       two different paths for the same ID and the
                       merged XSD fails with
                       "Duplicate key-sequence Magento_Config::config".
                -->
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="ETechFlow_AdminReindex::config"
                                      title="ETechFlow Admin Reindex Configuration"
                                      sortOrder="100"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
