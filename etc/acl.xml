<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Backend::system">
                    <resource id="Magento_Backend::tools">
                        <resource id="Magento_Indexer::index">
                            <resource id="ETechFlow_AdminReindex::run"
                                      title="Run Indexer Reindex from Admin"
                                      sortOrder="100"/>
                        </resource>
                    </resource>
                    <resource id="Magento_Backend::stores">
                        <resource id="Magento_Config::config">
                            <resource id="ETechFlow_AdminReindex::config"
                                      title="ETechFlow Admin Reindex Configuration"
                                      sortOrder="100"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
